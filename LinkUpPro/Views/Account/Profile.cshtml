@model Application.ViewModels.Account.ProfileViewModel

<h2>Mi Perfil</h2>

<div class="card p-3">

    <p><strong>Nombre:</strong> @Model.FirstName</p>

    <p><strong>Apellido:</strong> @Model.LastName</p>

    <p><strong>Usuario:</strong> @Model.UserName</p>

    <p><strong>Email:</strong> @Model.Email</p>

    <p><strong>Teléfono:</strong> @Model.PhoneNumber</p>

</div>

<a asp-action="Logout" class="btn btn-danger mt-3">
    Cerrar sesión
</a>