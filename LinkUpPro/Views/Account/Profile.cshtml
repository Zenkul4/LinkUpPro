@model LinkUpProject.Application.ViewModels.Account.ProfileViewModel

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                <!-- Renderizado de Avatar -->
                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center shadow-sm mx-auto mb-3 position-relative" style="width: 120px; height: 120px; font-size: 3.5rem; font-weight: bold; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img src="@Model.ProfilePictureUrl" alt="Foto de perfil" class="w-100 h-100" style="object-fit: cover;" />
                    }
                    else
                    {
                        @(string.IsNullOrEmpty(Model.FirstName) ? "U" : Model.FirstName.Substring(0, 1).ToUpper())
                    }
                </div>
                <h3 class="fw-bold mb-0">@Model.FirstName @Model.LastName</h3>
                <p class="text-muted">@@@Model.UserName</p>
            </div>
            
            <div class="card-body px-5 pb-4">
                <h5 class="fw-bold border-bottom pb-2 mb-3">Información Personal</h5>
                
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span class="text-muted fw-semibold">Nombre</span>
                        <span class="fw-medium">@Model.FirstName</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span class="text-muted fw-semibold">Apellido</span>
                        <span class="fw-medium">@Model.LastName</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span class="text-muted fw-semibold">Correo Electrónico</span>
                        <span class="fw-medium">@Model.Email</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span class="text-muted fw-semibold">Teléfono</span>
                        <span class="fw-medium">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "No especificado" : Model.PhoneNumber)</span>
                    </li>
                </ul>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-light fw-bold px-4">Volver al Feed</a>
                    
                    <!-- Logout seguro mediante POST -->
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-danger fw-bold px-4">Cerrar Sesión</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>