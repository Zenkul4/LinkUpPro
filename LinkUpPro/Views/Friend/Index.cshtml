@model LinkUpProject.Application.ViewModels.Friend.FriendDashboardViewModel

@{
    ViewData["Title"] = "Amigos";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success shadow-sm">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger shadow-sm">@TempData["ErrorMessage"]</div>
        }

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
            <div>
                <h2 class="h4 fw-bold mb-1">Amigos</h2>
                <p class="text-muted mb-0">Gestiona solicitudes, busca personas y revisa tus contactos.</p>
            </div>
            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                @Model.Friends.Count amigo@(Model.Friends.Count == 1 ? "" : "s")
            </span>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form asp-action="Index" method="get" class="row g-2 align-items-center">
                    <div class="col-md">
                        <input name="searchTerm"
                               value="@Model.SearchTerm"
                               class="form-control bg-light border-0"
                               placeholder="Buscar por nombre, usuario o correo" />
                    </div>
                    <div class="col-md-auto">
                        <button type="submit" class="btn btn-primary w-100">Buscar</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                    {
                        <div class="col-md-auto">
                            <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
                        </div>
                    }
                </form>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <section class="mb-4">
                <h3 class="h6 fw-bold text-muted mb-3">Resultados de busqueda</h3>

                @if (!Model.SearchResults.Any())
                {
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center text-muted py-4">
                            No encontramos usuarios activos con ese criterio.
                        </div>
                    </div>
                }
                else
                {
                    <div class="list-group shadow-sm">
                        @foreach (var user in Model.SearchResults)
                        {
                            <div class="list-group-item border-0 border-bottom">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 44px; height: 44px;">
                                            @(string.IsNullOrWhiteSpace(user.FullName) ? "U" : user.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="fw-bold">@user.FullName</div>
                                            <div class="small text-muted">@@@user.UserName · @user.MutualFriendsCount amigo@(user.MutualFriendsCount == 1 ? "" : "s") en comun</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-md-end">
                                        @if (string.IsNullOrWhiteSpace(user.RelationshipStatus))
                                        {
                                            <form asp-action="SendRequest" method="post" class="m-0">
                                                <input type="hidden" name="receiverId" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3">Enviar solicitud</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-secondary border rounded-pill px-3 py-2">@user.RelationshipStatus</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        }

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <section class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0 pt-3">
                        <h3 class="h6 fw-bold mb-0">Solicitudes recibidas</h3>
                    </div>
                    <div class="card-body pt-2">
                        @if (!Model.IncomingRequests.Any())
                        {
                            <p class="text-muted mb-0">No tienes solicitudes pendientes.</p>
                        }
                        else
                        {
                            @foreach (var request in Model.IncomingRequests)
                            {
                                <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 py-2 border-bottom">
                                    <div>
                                        <div class="fw-semibold">@request.SenderName</div>
                                        <div class="small text-muted">@@@request.SenderUserName · @request.SentAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <form asp-action="Accept" method="post" class="m-0">
                                            <input type="hidden" name="requestId" value="@request.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Aceptar</button>
                                        </form>
                                        <form asp-action="Reject" method="post" class="m-0">
                                            <input type="hidden" name="requestId" value="@request.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Rechazar</button>
                                        </form>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </section>
            </div>

            <div class="col-lg-6">
                <section class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0 pt-3">
                        <h3 class="h6 fw-bold mb-0">Solicitudes enviadas</h3>
                    </div>
                    <div class="card-body pt-2">
                        @if (!Model.OutgoingRequests.Any())
                        {
                            <p class="text-muted mb-0">No tienes solicitudes enviadas pendientes.</p>
                        }
                        else
                        {
                            @foreach (var request in Model.OutgoingRequests)
                            {
                                <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 py-2 border-bottom">
                                    <div>
                                        <div class="fw-semibold">@request.ReceiverName</div>
                                        <div class="small text-muted">@@@request.ReceiverUserName · @request.SentAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                    <form asp-action="Cancel" method="post" class="m-0">
                                        <input type="hidden" name="requestId" value="@request.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Cancelar</button>
                                    </form>
                                </div>
                            }
                        }
                    </div>
                </section>
            </div>
        </div>

        <section class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h3 class="h6 fw-bold mb-0">Mis amigos</h3>
            </div>
            <div class="card-body pt-2">
                @if (!Model.Friends.Any())
                {
                    <p class="text-muted mb-0">Todavia no tienes amigos agregados.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var friend in Model.Friends)
                        {
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div class="d-flex">
                                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 42px; height: 42px;">
                                                @(string.IsNullOrWhiteSpace(friend.FullName) ? "U" : friend.FullName.Substring(0, 1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-bold">@friend.FullName</div>
                                                <div class="small text-muted">@@@friend.UserName</div>
                                                <div class="small text-muted">@friend.MutualFriendsCount amigo@(friend.MutualFriendsCount == 1 ? "" : "s") en comun</div>
                                            </div>
                                        </div>
                                        <form asp-action="Remove" method="post" class="m-0">
                                            <input type="hidden" name="friendId" value="@friend.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Seguro que deseas eliminar esta amistad?');">
                                                Eliminar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    </div>
</div>
