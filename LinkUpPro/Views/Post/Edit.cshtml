@model LinkUpProject.Application.ViewModels.Post.SavePostViewModel

@{
    ViewData["Title"] = "Editar Publicación";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h4 class="fw-bold">Editar Publicación</h4>
            </div>
            <div class="card-body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                    </div>
                }

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ExistingMediaUrl" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Contenido</label>
                        <textarea asp-for="Content" class="form-control bg-light border-0" rows="4"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tipo de Contenido</label>
                            <select asp-for="ContentType" class="form-select bg-light border-0" id="editContentTypeSelect" onchange="toggleEditContentInputs()">
                                <option value="Texto">Texto</option>
                                <option value="Imagen">Imagen</option>
                                <option value="Video de YouTube">Video de YouTube</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Privacidad</label>
                            <select asp-for="Privacy" class="form-select bg-light border-0">
                                <option value="Solo amigos">Solo amigos</option>
                                <option value="Solo yo">Solo yo</option>
                            </select>
                        </div>
                    </div>

                    <div id="editImageInputDiv" class="mb-3 @(Model.ContentType == "Imagen" ? "" : "d-none")">
                        <label class="form-label fw-semibold">Subir nueva imagen (opcional)</label>
                        <input asp-for="MediaFile" class="form-control bg-light border-0" accept=".jpg,.jpeg,.png,.webp" />
                        <span asp-validation-for="MediaFile" class="text-danger small"></span>
                    </div>

                    <div id="editYoutubeInputDiv" class="mb-4 @(Model.ContentType == "Video de YouTube" ? "" : "d-none")">
                        <label class="form-label fw-semibold">Enlace de YouTube</label>
                        <input asp-for="YouTubeLink" class="form-control bg-light border-0" />
                        <span asp-validation-for="YouTubeLink" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="AllowComments" class="form-check-input" />
                        <label class="form-check-label fw-semibold">Permitir Comentarios</label>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light fw-bold px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary fw-bold px-4">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleEditContentInputs() {
            var type = document.getElementById('editContentTypeSelect').value;
            document.getElementById('editImageInputDiv').classList.add('d-none');
            document.getElementById('editYoutubeInputDiv').classList.add('d-none');

            if (type === 'Imagen') {
                document.getElementById('editImageInputDiv').classList.remove('d-none');
            } else if (type === 'Video de YouTube') {
                document.getElementById('editYoutubeInputDiv').classList.remove('d-none');
            }
        }
    </script>
}